# App
NODE_ENV=development
PORT=3000
APP_NAME=api

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=dev
DB_PASSWORD=devpass
DB_NAME=app_dev
DATABASE_URL=mysql://dev:devpass@localhost:3306/app_dev

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-must-be-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
